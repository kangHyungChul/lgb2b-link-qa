{
  "browser": {
    "showBrowser": true,
    "timeout": 30000,
    "areaWaitTimeout": 30000,
    "verificationMode": "navigate"
  },
  "viewports": {
    "pc": {
      "width": 1920,
      "height": 1080
    },
    "mobile": {
      "width": 390,
      "height": 844,
      "isMobile": true,
      "hasTouch": true
    }
  },
  "linkFilter": {
    "skipPatterns": ["^javascript:", "^mailto:", "^tel:", "^#"],
    "skipExternalDomains": false
  },
  "errorDetection": {
    "httpStatusCodes": [404, 410, 500, 502, 503],
    "urlPatterns": ["/404", "/error", "not-found", "page-not-found"],
    "titlePatterns": ["404", "not found", "error", "페이지를 찾을 수 없", "오류"],
    "bodyTextPatterns": ["page not found", "404", "페이지를 찾을 수 없습니다", "요청하신 페이지"]
  },
  "report": {
    "outputDir": "reports",
    "formats": ["json", "csv"]
  }
}
